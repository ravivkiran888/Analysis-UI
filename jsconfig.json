{
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "checkJs": true,
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": ["src/**/*", "vite.config.js", "*.d.ts"],
  "exclude": ["node_modules"]
}